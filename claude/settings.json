{
  "_comment": "Server-side Claude Code permissions. Symlinked into ~/.claude/settings.json by 'install.sh --server'. Mac uses its own ~/.claude/settings.json (not symlinked, not in this repo).",
  "theme": "dark",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Task(*)",
      "TaskCreate(*)",
      "TaskUpdate(*)",
      "TaskList(*)",
      "TaskGet(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "deny": [
      "Bash(sudo)",
      "Bash(sudo *)",
      "Bash(su)",
      "Bash(su *)",
      "Bash(doas *)",
      "Bash(pkexec *)",
      "Bash(chmod 777 *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -fr /)",
      "Bash(rm -fr /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -fr ~)",
      "Bash(rm -fr ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ..)",
      "Bash(rm -rf /home*)",
      "Bash(rm -rf /etc*)",
      "Bash(rm -rf /usr*)",
      "Bash(rm -rf /var*)",
      "Bash(rm -rf /boot*)",
      "Bash(mkfs*)",
      "Bash(mkfs.*)",
      "Bash(fdisk*)",
      "Bash(parted*)",
      "Bash(dd *)",
      "Bash(shred *)",
      "Bash(wipe *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push --mirror*)",
      "Bash(git push --delete*)",
      "Bash(git push origin main*)",
      "Bash(git push origin staging*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -d*)",
      "Bash(git clean -x*)",
      "Bash(git branch -D *)",
      "Bash(git branch --delete --force*)",
      "Bash(git tag -d *)",
      "Bash(git update-ref -d *)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(journalctl --rotate*)",
      "Bash(journalctl --vacuum-time*)",
      "Bash(journalctl --vacuum-size*)",
      "Bash(journalctl --vacuum-files*)",
      "Bash(journalctl --flush*)",
      "Bash(journalctl --sync*)",
      "Bash(journalctl --relinquish-var*)",
      "Bash(journalctl --smart-relinquish-var*)",
      "Bash(journalctl --update-catalog*)",
      "Bash(journalctl --setup-keys*)"
    ]
  }
}
