#!/usr/bin/env bash
# Open any markdown file in a readable terminal viewer.
# Inside Zellij: vertical split on the right by default; pass
#   MARKDOWN_VIEW_PANE=floating to use a centered floating pane instead.
# Outside Zellij: runs inline.
#
# Picks the best available viewer in order:
#   frogmouth-tuned (if frogmouth installed) → glow → less
#
# Use this for plans (docs/plans/*.md), SKILL.md files, READMEs,
# generated docs — anything markdown.

set -euo pipefail

usage() {
  echo "usage: markdown-view <file.md>" >&2
}

[ "${1:-}" != "" ] || { usage; exit 2; }

MD_PATH="$1"
[ -f "$MD_PATH" ] || { echo "ERROR: markdown file not found: $MD_PATH" >&2; exit 1; }

has_frogmouth() {
  local python="${FROGMOUTH_PYTHON:-}"
  if [ -z "$python" ]; then
    if [ -x "$HOME/.local/share/pipx/venvs/frogmouth/bin/python" ]; then
      python="$HOME/.local/share/pipx/venvs/frogmouth/bin/python"
    else
      python="$(command -v python3 || true)"
    fi
  fi

  [ -n "$python" ] && "$python" -c 'import frogmouth' >/dev/null 2>&1
}

if command -v frogmouth-tuned >/dev/null 2>&1 && has_frogmouth; then
  VIEWER=(frogmouth-tuned "$MD_PATH")
elif command -v glow >/dev/null 2>&1; then
  VIEWER=(glow -p "$MD_PATH")
else
  VIEWER=(less -R "$MD_PATH")
fi

if [ -n "${ZELLIJ:-}" ] && command -v zellij >/dev/null 2>&1; then
  # MARKDOWN_VIEW_PANE is the new env name; PLAN_VIEW_PANE is kept for
  # backward compatibility with shell exports / aliases users may have.
  PANE_MODE="${MARKDOWN_VIEW_PANE:-${PLAN_VIEW_PANE:-right}}"
  PANE_NAME="md: $(basename "$MD_PATH")"
  PANE_CWD="$(dirname "$MD_PATH")"

  # Anchor the new pane to the CALLER's tab, not whichever tab happens to
  # be focused right now. Without this, an agent running in tab A that
  # opens markdown-view while the operator is looking at tab B will see
  # its preview pane appear in tab B — confusing. By focusing the
  # caller's pane first, we force `new-pane` to land in the right tab.
  #
  # $ZELLIJ_PANE_ID is set by Zellij for every process running in a pane.
  # If it's missing (rare — non-pane child somehow), skip the anchor
  # step and let new-pane fall back to whatever's focused.
  if [ -n "${ZELLIJ_PANE_ID:-}" ]; then
    zellij action focus-pane-id "$ZELLIJ_PANE_ID" 2>/dev/null || true
  fi

  case "$PANE_MODE" in
    right|down)
      zellij action new-pane -d "$PANE_MODE" \
        --name "$PANE_NAME" --cwd "$PANE_CWD" -- "${VIEWER[@]}"
      ;;
    floating)
      zellij action new-pane --floating --width 90% --height 90% \
        --name "$PANE_NAME" --cwd "$PANE_CWD" -- "${VIEWER[@]}"
      ;;
    *)
      echo "markdown-view: unknown MARKDOWN_VIEW_PANE=$PANE_MODE (expected right|down|floating)" >&2
      exit 2
      ;;
  esac
else
  exec "${VIEWER[@]}"
fi
